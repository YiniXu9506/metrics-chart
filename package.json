{
  "name": "metrics-chart",
  "version": "1.0.27",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/YiniXu9506/metrics-chart"
  },
  "homepage": "https://github.com/YiniXu9506/metrics-chart",
  "bugs": {
    "url": "https://github.com/YiniXu9506/metrics-chart/issues"
  },
  "targets": {
    "main": {
      "source": "src/index.ts",
      "distDir": "dist/index.js",
      "optimize": true,
      "includeNodeModules": {
        "@elastic/charts": false,
        "ahooks": false,
        "react": false,
        "react-dom": false
      }
    }
  },
  "dependencies": {
    "@baurine/grafana-value-formats": "^1.0.5",
    "dayjs": "^1.11.5",
    "react-use": "^17.4.0",
    "string-template": "^1.0.0",
    "typescript": "^4.7.4"
  },
  "devDependencies": {
    "@parcel/packager-ts": "^2.7.0",
    "@parcel/reporter-bundle-analyzer": "^2.7.0",
    "@parcel/transformer-sass": "^2.7.0",
    "@parcel/transformer-typescript-types": "^2.7.0",
    "@storybook/addon-essentials": "^7.6.20",
    "@storybook/addon-interactions": "^7.6.20",
    "@storybook/react-webpack5": "^7.6.20",
    "@types/react": "^17.0.2",
    "autoprefixer": "^10.4.19",
    "parcel": "^2.7.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-modules": "^6.0.0",
    "postcss-prefixwrap": "^1.47.0",
    "sass": "^1.75.0",
    "storybook": "^7.6.20",
    "ts-node": "^10.9.2",
    "typescript": "^4.7.4",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "@elastic/charts": "^47.2.1",
    "ahooks": "^3.7.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "scripts": {
    "start": "npm run build:css && parcel start",
    "build": "npm run build:css && npm run build:css-theme && npm run build:js && npm run build:type",
    "build:css": "node scripts/build-theme-css.mjs .css",
    "build:css-theme": "node scripts/build-theme-css.mjs dist/theme",
    "build:js": "node scripts/build-js.mjs",
    "build:theme": "node scripts/build-js.mjs --theme-only",
    "build:type": "npx -p typescript tsc --outDir dist/types",
    "build:analyze": "parcel build --reporter @parcel/reporter-bundle-analyzer",
    "storybook": "npm run build:css && STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "npm run build:css && STORYBOOK_DISABLE_TELEMETRY=1 storybook build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
